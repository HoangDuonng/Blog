&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="err">&lt;/span>&lt;span class="k">RUN&lt;/span> npm run build&lt;span class="err">
&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="err">&lt;/span>&lt;span class="k">CMD&lt;/span> &lt;span class="p">[&lt;/span>&lt;span class="s2">&amp;#34;node&amp;#34;&lt;/span>&lt;span class="p">,&lt;/span> &lt;span class="s2">&amp;#34;dist/server.js&amp;#34;&lt;/span>&lt;span class="p">]&lt;/span>&lt;span class="err">
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div>&lt;p>&lt;strong>Vấn đề:&lt;/strong>&lt;/p>
&lt;ul>
&lt;li>❌ Base image lớn (&lt;code>node:18&lt;/code> ~ 900 MB)&lt;/li>
&lt;li>❌ &lt;code>COPY . .&lt;/code> trước &lt;code>npm install&lt;/code> → mọi thay đổi code đều rebuild dependencies&lt;/li>
&lt;li>❌ Không có &lt;code>.dockerignore&lt;/code> → copy cả &lt;code>node_modules&lt;/code>, &lt;code>.git&lt;/code>&lt;/li>
&lt;li>❌ Không dùng multi-stage → image cuối chứa devDependencies&lt;/li>
